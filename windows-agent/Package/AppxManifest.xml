<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX manifest that gives the agent package identity so
  UserNotificationListener.NotificationChanged fires (event-driven, no polling).
  Publisher must exactly match the signing certificate subject; build-msix.ps1
  uses CN=notify-bridge-dev for both.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap5 rescap">

  <Identity
    Name="notify-bridge"
    Publisher="CN=notify-bridge-dev"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Notify Bridge Agent</DisplayName>
    <PublisherDisplayName>notify-bridge</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="App" Executable="NotifyBridgeAgent.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Notify Bridge Agent"
        Description="Forward Windows notifications to the Linux host"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile ShortName="Notify Bridge" />
      </uap:VisualElements>
      <Extensions>
        <!-- Auto-start the packaged app at logon (keeps package identity, which
             the loose-exe HKCU Run key would not). -->
        <uap5:Extension Category="windows.startupTask" Executable="NotifyBridgeAgent.exe" EntryPoint="Windows.FullTrustApplication">
          <uap5:StartupTask TaskId="NotifyBridgeAgent" Enabled="true" DisplayName="Notify Bridge Agent" />
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for a packaged full-trust Win32 desktop app. -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
